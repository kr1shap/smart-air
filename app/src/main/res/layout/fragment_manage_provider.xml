<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colour_blue"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage Provider"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/colour_white"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Generate an invite code to share with your healthcare provider"
            android:textSize="14sp"
            android:textColor="@color/colour_white"
            android:layout_marginBottom="24dp" />

        <!-- Invite Code Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_code_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No active invite code"
                    android:textSize="14sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_invite_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Code: 123456"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/colour_blue"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_expiry_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expires: Jan 01, 2025"
                    android:textSize="12sp"
                    android:textColor="@android:color/darker_gray"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_generate_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generate Code"
            android:textAllCaps="false"
            android:background="@color/colour_white"
            android:textColor="@color/colour_blue" />

        <!-- Provider List Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Providers"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colour_white"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No providers linked yet"
            android:textSize="14sp"
            android:textColor="@color/colour_white"
            android:alpha="0.7" />

        <!-- TODO: Add RecyclerView for provider list -->

    </LinearLayout>
</ScrollView>